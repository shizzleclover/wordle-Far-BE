MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/wordle-duel?retryWrites=true&w=majority
JWT_SECRET=your-secret-key-here
PORT=3001
# One origin, or comma-separated (no spaces after commas is fine)
CLIENT_URL=http://localhost:5173
# Production example:
# CLIENT_URL=https://wordle-far-fe.vercel.app
# Optional: add Vercel preview pattern via extra deploy URL:
# CLIENT_URL=https://wordle-far-fe.vercel.app,https://wordle-far-fe-git-main-yourteam.vercel.app

# Milliseconds to wait for a disconnected player to reconnect before forfeit (default 90000)
DISCONNECT_GRACE_MS=90000

# Per-guess word length when creating a room (default 3-20, hard cap 2-32 in code)
# WORD_LENGTH_MIN=3
# WORD_LENGTH_MAX=20
